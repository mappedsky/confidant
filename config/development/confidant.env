AWS_ACCESS_KEY_ID=1
AWS_SECRET_ACCESS_KEY=1
AWS_DEFAULT_REGION=us-east-1
DEBUG=true
HOST=0.0.0.0
PORT=80
JWKS_URL=http://authentik-server:9000/application/o/confidant/jwks/
OIDC_AUTHORITY=http://localhost:9000/application/o/confidant
OIDC_CLIENT_ID=confidant
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_SCOPE=openid email profile
# These OIDC settings are consumed by the backend and surfaced to the SPA via /v1/auth_config.
KMS_URL=http://kms:8080
SSLIFY=false
DYNAMODB_CREATE_TABLE=true
DYNAMODB_URL=http://dynamodb:8080
DYNAMODB_TABLE=confidant-development
DYNAMODB_CREATE_TABLE=true
HISTORY_PAGE_LIMIT=20
KMS_MASTER_KEY=alias/atrest
MAINTENANCE_MODE_TOUCH_FILE=/config/maintenance
# Uncomment this to test grunt compiled/minified styles, components, images, etc
#STATIC_FOLDER=../dist
